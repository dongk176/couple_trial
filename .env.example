# Supabase Postgres (5wd band와 동일한 변수명)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&sslmode=require&connection_limit=1"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require&connect_timeout=10"

# S3 (5wd band와 동일한 변수명)
AWS_REGION="ap-northeast-2"
AWS_DEFAULT_REGION="ap-northeast-2"
AWS_ACCESS_KEY_ID="YOUR_AWS_ACCESS_KEY_ID"
AWS_SECRET_ACCESS_KEY="YOUR_AWS_SECRET_ACCESS_KEY"
S3_BUCKET="YOUR_S3_BUCKET"
AWS_S3_BUCKET="YOUR_S3_BUCKET"
S3_PUBLIC_BASE_URL=""
AWS_S3_PUBLIC_URL=""

# AI (artiroom-mvp와 동일한 기본 키 체계)
OPENAI_API_KEY="YOUR_OPENAI_API_KEY"
OPENAI_BOGOPA_MODEL="gpt-4.1-mini"

# 커플법정은 bogopa와 같은 DB 환경변수명을 쓰고, Prisma는 couple_court schema만 사용합니다.
NEXTAUTH_SECRET="CHANGE_ME_TO_A_LONG_RANDOM_SECRET"
COUPLE_COURT_ADMIN_SECRET="CHANGE_ME_TO_A_LONG_RANDOM_ADMIN_SECRET"

# Apple Sign In
# APPLE_CLIENT_SECRET를 직접 넣거나,
# APPLE_TEAM_ID + APPLE_KEY_ID + APPLE_PRIVATE_KEY로 서버에서 JWT를 자동 생성할 수 있습니다.
APPLE_CLIENT_ID="co.kr.bogopa.web.signin"
APPLE_TEAM_ID=""
APPLE_KEY_ID=""
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# APPLE_CLIENT_SECRET=""

# Payment card hashing secret (32+ chars random string)
PAYMENT_CARD_HASH_SECRET="CHANGE_ME_TO_A_LONG_RANDOM_SECRET"

# In-App Purchase (IAP)
# 개발 중에는 true로 두면 /api/iap/verify가 mock 검증으로 동작합니다.
# 운영에서는 false로 두고 실제 App Store/Google Play 검증을 붙이세요.
IAP_ALLOW_MOCK_PURCHASES="true"

# 선택: 스토어 상품 ID 커스텀 (비워두면 기본값 사용)
IAP_IOS_MEMORY_PASS_MONTHLY_ID="co.kr.bogopa.pass.monthly"
IAP_ANDROID_MEMORY_PASS_MONTHLY_ID="co.kr.bogopa.pass.monthly"
IAP_IOS_MEMORY_PACK_200_ID="co.kr.bogopa.app.memory.200"
IAP_ANDROID_MEMORY_PACK_200_ID="co.kr.bogopa.app.memory.200"
IAP_IOS_MEMORY_PACK_1000_ID="co.kr.bogopa.app.memory.1000"
IAP_ANDROID_MEMORY_PACK_1000_ID="co.kr.bogopa.app.memory.1000"
IAP_IOS_MEMORY_PACK_20000_ID="co.kr.bogopa.app.memory.20000"
IAP_ANDROID_MEMORY_PACK_20000_ID="co.kr.bogopa.app.memory.20000"
IAP_IOS_UNLIMITED_24H_ID="co.kr.bogopa.unlimited.24h"
IAP_ANDROID_UNLIMITED_24H_ID="co.kr.bogopa.unlimited.24h"

BOGOPA_LOCAL_LOGIN_ID_2=
BOGOPA_LOCAL_LOGIN_PASSWORD_2=

BOGOPA_LOCAL_LOGIN_ACCOUNTS=
